          </action>
          <action type="write_pv">
            <pv_name>$(Sys)$(Dev)$(Mtr).STOP</pv_name>
            <value>0</value>
            <description>Write PV</description>
          </action>
        </actions>
        <text>Stop</text>
        <x>665</x>
        <y>2</y>
        <width>70</width>
        <height>20</height>
        <foreground_color>
          <color red="255" green="0" blue="0">
          </color>
        </foreground_color>
        <tooltip>$(actions)</tooltip>
      </widget>
      <widget type="action_button" version="3.0.0">
        <name>More Options_3</name>
        <actions>
          <action type="open_display">
            <file>../../common/motor/motor_all.bob</file>
            <macros>
              <NAME>MDrive:1</NAME>
            </macros>
            <target>tab</target>
            <description>Motor Config</description>
          </action>
          <action type="open_display">
            <file>../../common/motor/mdriveDetail.bob</file>
            <macros>
              <NAME>MDrive:1</NAME>
            </macros>
            <target>tab</target>
            <description>MDrive Detail</description>
          </action>
          <action type="open_display">
            <file>../../adl/asynRecord.bob</file>
            <macros>
              <NAME>MDrive:1</NAME>
              <P>$(CntlSys)</P>
              <R>{$(CntlDev)}Asyn</R>
            </macros>
            <target>tab</target>
            <description>Asyn</description>
          </action>
        </actions>
        <text>More</text>
        <x>740</x>
        <y>2</y>
        <width>70</width>
        <height>20</height>
        <font>
          <font family="Liberation Sans" style="BOLD" size="14.0">
          </font>
        </font>
        <tooltip>$(actions)</tooltip>
      </widget>
      <widget type="textupdate" version="2.0.0">
        <name>Description_3</name>
        <pv_name>$(Sys)$(Dev)$(Mtr).DESC</pv_name>
        <y>2</y>
        <width>200</width>
        <font>
          <font family="Liberation Sans" style="BOLD" size="14.0">
          </font>
        </font>
        <horizontal_alignment>1</horizontal_alignment>
