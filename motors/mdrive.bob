        <x>360</x>
        <y>2</y>
        <width>115</width>
        <horizontal_alignment>1</horizontal_alignment>
        <vertical_alignment>1</vertical_alignment>
      </widget>
      <widget type="led" version="2.0.0">
        <name>Positive Limit_3</name>
        <pv_name>$(Sys)$(Dev)$(Mtr).HLS</pv_name>
        <x>477</x>
        <y>2</y>
        <width>16</width>
        <off_color>
          <color red="128" green="0" blue="0">
          </color>
        </off_color>
        <on_color>
          <color red="255" green="0" blue="0">
          </color>
        </on_color>
        <square>true</square>
      </widget>
      <widget type="action_button" version="3.0.0">
        <name>Tweak Reverse_3</name>
        <actions>
          <action type="write_pv">
            <pv_name>$(Sys)$(Dev)$(Mtr).TWR</pv_name>
            <value>1</value>
            <description>Tweak Reerse</description>
          </action>
        </actions>
        <pv_name>$(Sys)$(Dev)$(Mtr).TWR</pv_name>
        <text>&lt;</text>
        <x>497</x>
        <y>2</y>
        <width>24</width>
        <height>20</height>
      </widget>
      <widget type="textentry" version="3.0.0">
        <name>Tweak Value_3</name>
        <pv_name>$(Sys)$(Dev)$(Mtr).TWV</pv_name>
        <x>521</x>
        <y>2</y>
        <width>115</width>
      </widget>
      <widget type="action_button" version="3.0.0">
        <name>Tweak Forward_3</name>
        <actions>
          <action type="write_pv">
            <pv_name>$(Sys)$(Dev)$(Mtr).TWF</pv_name>
            <value>1</value>
            <description>Tweak Forward</description>
          </action>
        </actions>
        <pv_name>$(Sys)$(Dev)$(Mtr).TWF</pv_name>
        <text>&gt;</text>
        <x>636</x>
        <y>2</y>
        <width>24</width>
