    <rules>
      <rule name="Font color Rule" prop_id="foreground_color" out_exp="false">
        <exp bool_exp="(pv0!=1)&amp;&amp;(pv0!=0)">
          <value>
            <color name="Major" red="255" green="0" blue="0">
            </color>
          </value>
        </exp>
        <exp bool_exp="(pv0==1)||(pv0==0)">
          <value>
            <color red="78" green="154" blue="6">
            </color>
          </value>
        </exp>
        <pv_name>$(P){$(Q)}Status</pv_name>
      </rule>
    </rules>
